---
import Base from './Base.astro';

interface Props {
  title: string;
  date: string;
  description?: string;
}

const { title, date, description } = Astro.props;

const formatted = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={title} description={description}>
  <article>
    <header class="mb-12">
      <h1 class="font-display text-5xl font-bold leading-tight mb-6">{title}</h1>
      <time class="text-xs tracking-widest uppercase text-muted">{formatted}</time>
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</Base>

<style>
  .prose {
    font-family: 'Lora', Georgia, serif;
    font-size: 1.05rem;
    line-height: 1.8;
    color: #1a1a1a;
  }
  .prose p {
    margin-bottom: 1.5rem;
  }
  .prose h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.6rem;
    font-weight: 700;
    margin-top: 3rem;
    margin-bottom: 1rem;
    color: #1a1a1a;
  }
  .prose h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .prose a {
    border-bottom: 1px solid #1a1a1a;
    text-decoration: none;
    color: #1a1a1a;
  }
  .prose a:hover {
    opacity: 0.6;
  }
  .prose em {
    font-style: italic;
  }
  .prose strong {
    font-weight: 600;
  }
  .prose code {
    font-family: monospace;
    font-size: 0.875rem;
    background: #f5f5f5;
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
  }
  .prose blockquote {
    border-left: 2px solid #e0e0e0;
    padding-left: 1.25rem;
    color: #666666;
    font-style: italic;
    margin: 1.5rem 0;
  }
  .prose hr {
    border: none;
    border-top: 1px solid #e0e0e0;
    margin: 2.5rem 0;
  }
  .prose table {
    width: 100%;
    overflow-x: auto;
    display: block;
    border-collapse: collapse;
    font-size: 0.9rem;
    margin: 2rem 0;
  }
  .prose th {
    text-align: left;
    font-weight: 600;
    padding: 0.6rem 1rem;
    border-bottom: 1px solid #e0e0e0;
    white-space: nowrap;
    color: #1a1a1a;
  }
  .prose td {
    padding: 0.6rem 1rem;
    border-bottom: 1px solid #f0f0f0;
    color: #333333;
    vertical-align: top;
  }
  .prose tr:last-child td {
    border-bottom: none;
  }
  .prose ul {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .prose li {
    margin-bottom: 0.4rem;
  }
  .prose ol {
    list-style: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }
</style>
