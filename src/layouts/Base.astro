---
interface Props {
  title?: string;
  description?: string;
}

const { title = 'Tommaso Dreossi', description = 'Personal website and blog.' } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title === 'Tommaso Dreossi' ? title : `${title} — Tommaso Dreossi`}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Space+Mono&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-bg text-text min-h-screen font-sans antialiased">
    <div class="max-w-2xl mx-auto px-6 py-16">
      <header class="flex items-center justify-between mb-20">
        <a href="/" class="text-text font-medium tracking-tight hover:opacity-70 transition-opacity">
          Tommaso Dreossi
        </a>
        <nav class="flex gap-8">
          <a href="/" class="text-muted hover:text-text transition-colors text-sm">Home</a>
          <a href="/blog" class="text-muted hover:text-text transition-colors text-sm">Blog</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="mt-24 pt-8 border-t border-border">
        <div class="flex gap-6">
          <a href="https://github.com/dreossi" class="text-muted hover:text-text transition-colors text-sm">GitHub</a>
          <a href="/blog/feed.xml" class="text-muted hover:text-text transition-colors text-sm">RSS</a>
        </div>
      </footer>
    </div>
  </body>
</html>
