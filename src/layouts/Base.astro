---
interface Props {
  title?: string;
  description?: string;
}

const { title = 'Tommaso Dreossi', description = 'Personal website and blog.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title === 'Tommaso Dreossi' ? title : `${title} — Tommaso Dreossi`}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Lora:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-bg text-text font-serif antialiased">
    <div class="max-w-2xl mx-auto px-8 pt-16 pb-24">
      <header class="mb-16 flex items-center justify-between">
        <a href="/" class="inline-block text-xs tracking-widest uppercase border-b border-text pb-0.5 hover:opacity-60 transition-opacity font-serif">
          Tommaso Dreossi
        </a>
        <nav class="flex gap-6">
          <a href="https://github.com/dreossi" class="text-xs tracking-widest uppercase text-muted hover:text-text transition-colors">GitHub</a>
          <a href="https://www.linkedin.com/in/tommaso-dreossi/" class="text-xs tracking-widest uppercase text-muted hover:text-text transition-colors">LinkedIn</a>
          <a href="https://scholar.google.com/citations?user=wlLtbpoAAAAJ&hl=en" class="text-xs tracking-widest uppercase text-muted hover:text-text transition-colors">Scholar</a>
          <a href="/rss.xml" class="text-xs tracking-widest uppercase text-muted hover:text-text transition-colors">RSS</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="mt-24"></footer>
    </div>
  </body>
</html>
