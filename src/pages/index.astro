---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);
---

<Base>
  <section class="mb-20">
    <h1 class="text-2xl font-medium tracking-tight text-text mb-4">Tommaso Dreossi</h1>
    <p class="text-muted leading-relaxed max-w-lg">
      I write about machine learning, software, and ideas I find worth thinking about.
    </p>
  </section>

  <section>
    <h2 class="text-xs font-mono text-muted uppercase tracking-widest mb-8">Recent writing</h2>
    <ul class="space-y-6">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.slug}`} class="group flex items-baseline justify-between gap-4">
            <span class="text-text group-hover:opacity-70 transition-opacity">
              {post.data.title}
            </span>
            <span class="text-muted text-sm font-mono shrink-0">
              {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
            </span>
          </a>
        </li>
      ))}
    </ul>
    {posts.length > 0 && (
      <a href="/blog" class="inline-block mt-10 text-sm text-muted hover:text-text transition-colors">
        All posts →
      </a>
    )}
  </section>
</Base>
