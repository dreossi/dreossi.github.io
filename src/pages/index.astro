---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Base>
  <section class="mb-20">
    <h1 class="font-display text-5xl font-bold mb-10 leading-tight">Tommaso Dreossi</h1>
    <div class="prose-home">
      <p>I build AI for scientific problems.</p>
      <p>
        At <a href="https://arena-ai.com/">Arena</a>, I'm developing a foundation model for electromagnetism, surrogate models for EM simulation,
        and inverse design pipelines using generative diffusion models.
      </p>
      <p>
        Previously at <a href="https://www.insitro.com/">insitro</a>, I led ML for ALS target discovery and built self-supervised and computer vision
        models for high-content cell imaging and omics.
      </p>
      <p>
        I did my PhD on reachability analysis for nonlinear dynamical systems and spent three years at UC Berkeley
        developing testing techniques for AI-enabled robotic and cyber-physical systems.
      </p>
    </div>
  </section>

  <section>
    <h2 class="text-xs tracking-widest uppercase text-muted mb-8">Writing</h2>
    <ul class="space-y-8">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.slug}`} class="group block">
            <strong class="font-serif font-normal text-lg border-b border-text group-hover:opacity-60 transition-opacity">
              {post.data.title}
            </strong>
            {post.data.description && (
              <p class="mt-1 text-muted leading-snug">{post.data.description}</p>
            )}
          </a>
        </li>
      ))}
    </ul>
  </section>
</Base>

<style>
  .prose-home p {
    font-size: 1rem;
    line-height: 1.75;
    color: #1a1a1a;
    margin-bottom: 1rem;
  }
  .prose-home a {
    border-bottom: 1px solid #1a1a1a;
    text-underline-offset: 2px;
  }
  .prose-home a:hover {
    opacity: 0.6;
  }
</style>
