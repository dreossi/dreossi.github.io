---
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet" />

<div class="pai-wrap">
  <p class="pai-caption"><strong>Tab. 1</strong> — Physical AI architectures mapped to the Perception–Control–Model–Optimize taxonomy. The table is illustrative rather than comprehensive: entries are representative examples of each combination, not an exhaustive catalog. Hover over a block to see seminal papers.</p>
  <div class="pai-col-headers">
    <div class="pai-col-h" id="pai-ch0">Perception</div>
    <div class="pai-col-h" id="pai-ch1">Control</div>
    <div class="pai-col-h" id="pai-ch2">Model</div>
    <div class="pai-col-h" id="pai-ch3">Optimize</div>
  </div>
  <div id="pai-chart"></div>
  <div id="pai-refs"></div>
</div>

<style is:global>
  .pai-wrap {
    width: 100%;
    margin: 2rem 0;
    font-family: 'Lora', Georgia, serif;
  }
  .pai-col-headers {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    margin: 0 8px;
    background: #e0e0e0;
  }
  .pai-col-h {
    padding: 9px 0 8px;
    text-align: center;
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 700;
    font-style: normal;
    font-size: 15px;
    color: #ffffff;
  }
  .pai-col-h:first-child { border-radius: 4px 0 0 0; }
  .pai-col-h:last-child  { border-radius: 0 4px 0 0; }
  #pai-chart { width: 100%; cursor: default; }
  #pai-refs {
    width: 100%;
    height: 150px;
    overflow: hidden;
    padding: 12px 8px 6px;
    border-top: 1px solid #e0e0e0;
    margin-top: 4px;
    font-family: 'Lora', Georgia, serif;
    font-size: 0.80rem;
    color: #888888;
    line-height: 1.5;
    box-sizing: border-box;
  }
  #pai-refs .ref-header {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 0.72rem;
    font-weight: 700;
    color: #1a1a1a;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 6px;
  }
  #pai-refs .ref-item {
    display: flex;
    gap: 10px;
    margin-bottom: 2px;
  }
  #pai-refs .ref-year {
    font-weight: 600;
    color: #555;
    min-width: 34px;
    flex-shrink: 0;
  }
  .pai-caption {
    font-family: 'Lora', Georgia, serif;
    font-size: 0.85rem;
    color: #999;
    font-style: italic;
    margin-bottom: 10px;
    text-align: left;
    line-height: 1.6;
  }
  .pai-caption strong {
    font-style: normal;
    color: #555;
  }
</style>

<script is:inline type="module">
import * as Plot from "https://cdn.jsdelivr.net/npm/@observablehq/plot@0.6/+esm";

function hslToRgb(h, s, l) {
  s /= 100; l /= 100;
  const k = n => (n + h / 30) % 12;
  const a = s * Math.min(l, 1 - l);
  const f = n => l - a * Math.max(-1, Math.min(k(n) - 3, Math.min(9 - k(n), 1)));
  return [Math.round(f(0) * 255), Math.round(f(8) * 255), Math.round(f(4) * 255)];
}
function toHex([r, g, b]) {
  return '#' + [r, g, b].map(v => v.toString(16).padStart(2, '0')).join('');
}
function blend(...rgbs) {
  const n = rgbs.length;
  return [
    Math.round(rgbs.reduce((s, c) => s + c[0], 0) / n),
    Math.round(rgbs.reduce((s, c) => s + c[1], 0) / n),
    Math.round(rgbs.reduce((s, c) => s + c[2], 0) / n),
  ];
}

const COL_HSL = [
  [229, 53, 43],
  [346, 62, 42],
  [168, 58, 28],
  [ 38, 82, 38],
];
const COL_RGB = COL_HSL.map(([h, s, l]) => hslToRgb(h, s, l));
const COL_HEX = COL_RGB.map(toHex);
const BG_HEX  = COL_HSL.map(([h]) => toHex(hslToRgb(h, 55, 95)));

COL_HEX.forEach((hex, i) => {
  const el = document.getElementById(`pai-ch${i}`);
  if (el) el.style.background = hex;
});

function blockColor(fc, tc) {
  const cols = Array.from({ length: tc - fc + 1 }, (_, i) => COL_RGB[fc + i]);
  return toHex(blend(...cols));
}

const GAP = 0.055;
const N   = 5;

const blocks = [
  { name: "State Estimation",      sub: "ViT · DINO · SAM · YOLO",         fc:0, tc:0, row:0,
    refs: [
      { year:2016, auth:"Redmon et al.",      title:"You Only Look Once: Unified, Real-Time Object Detection (YOLO)" },
      { year:2021, auth:"Dosovitskiy et al.", title:"An Image is Worth 16×16 Words (ViT)" },
      { year:2024, auth:"Ravi et al.",        title:"SAM 2: Segment Anything in Images and Videos" },
      { year:2025, auth:"Siméoni et al.",     title:"DINOv3" },
    ]},
  { name: "Policy Learning",       sub: "ACT · Diffusion Policy · BESO",   fc:1, tc:1, row:0,
    refs: [
      { year:2023, auth:"Chi et al.",  title:"Diffusion Policy: Visuomotor Policy Learning via Action Diffusion" },
      { year:2023, auth:"Zhao et al.", title:"Learning Fine-Grained Bimanual Manipulation with Low-Cost Hardware (ACT)" },
    ]},
  { name: "Surrogates",            sub: "Neural ODE · GNS · GraphCast",    fc:2, tc:2, row:0,
    refs: [
      { year:2018, auth:"Chen et al.",             title:"Neural Ordinary Differential Equations" },
      { year:2020, auth:"Sanchez-Gonzalez et al.", title:"Learning to Simulate Complex Physics with Graph Networks (GNS)" },
      { year:2023, auth:"Lam et al.",              title:"GraphCast: Learning Skillful Medium-Range Global Weather Forecasting" },
    ]},
  { name: "Bayesian Optimization", sub: "GP · SAASBO · TuRBO",             fc:3, tc:3, row:0,
    refs: [
      { year:2019, auth:"Eriksson et al.",      title:"Scalable Global Optimization via Local Bayesian Optimization (TuRBO)" },
      { year:2021, auth:"Eriksson & Jankowiak", title:"High-Dimensional Bayesian Optimization with Sparse Axis-Aligned Subspaces (SAASBO)" },
    ]},
  { name: "PINNs",                 sub: "hp-VPINNs · DeepXDE",             fc:2, tc:3, row:1,
    refs: [
      { year:2019, auth:"Raissi et al.",   title:"Physics-Informed Neural Networks" },
      { year:2021, auth:"Kharazmi et al.", title:"hp-VPINNs: Variational Physics-Informed Neural Networks with Domain Decomposition" },
      { year:2021, auth:"Lu et al.",       title:"DeepXDE: A Deep Learning Library for Solving Differential Equations" },
    ]},
  { name: "Neural Operators",      sub: "FNO · DeepONet · operator learning", fc:2, tc:3, row:2,
    refs: [
      { year:2021, auth:"Lu et al.", title:"Learning Nonlinear Operators via DeepONet" },
      { year:2021, auth:"Li et al.", title:"Fourier Neural Operator for Parametric Partial Differential Equations (FNO)" },
    ]},
  { name: "VLAs",                  sub: "GR00T · RT-2 · π₀",               fc:0, tc:1, row:3,
    refs: [
      { year:2023, auth:"Brohan et al.", title:"RT-2: Vision-Language-Action Models Transfer Web Knowledge to Robotic Control" },
      { year:2024, auth:"Black et al.",  title:"π₀: A Vision-Language-Action Flow Model for General Robot Control" },
      { year:2025, auth:"NVIDIA",        title:"GR00T N1: An Open Foundation Model for Generalist Humanoid Robots" },
    ]},
  { name: "Generative Design",     sub: "RFDiffusion · MatterGen · GNoME", fc:2, tc:3, row:3,
    refs: [
      { year:2023, auth:"Watson et al.",   title:"De novo design of protein structure and function with RFDiffusion" },
      { year:2023, auth:"Merchant et al.", title:"Scaling deep learning for materials discovery (GNoME)" },
      { year:2024, auth:"Zeni et al.",     title:"MatterGen: A Generative Model for Inorganic Materials Design" },
    ]},
  { name: "World Models",          sub: "Cosmos · DreamerV3 · JEPA",        fc:0, tc:2, row:4,
    refs: [
      { year:2023, auth:"Hafner et al.", title:"Mastering Diverse Domains through World Models (DreamerV3)" },
      { year:2025, auth:"Meta AI",       title:"V-JEPA 2: Self-Supervised Video Models Enable Understanding, Prediction and Planning" },
      { year:2025, auth:"NVIDIA",        title:"Cosmos: World Foundation Model Platform for Physical AI" },
    ]},
].map(b => ({ ...b, color: blockColor(b.fc, b.tc) }));

const data = blocks.map(b => {
  const yBase = N - 1 - b.row;
  return {
    ...b,
    x1: b.fc + GAP,    x2: b.tc + 1 - GAP,
    y1: yBase + GAP,   y2: yBase + 1 - GAP,
    cx: (b.fc + b.tc + 1) / 2,
    cy: yBase + 0.5,
  };
});

const container = document.getElementById("pai-chart");
const w = Math.min(container ? (container.offsetWidth || 780) : 780, 780);
const h = Math.round(w * 0.507);

const chart = Plot.plot({
  width:        w,
  height:       h,
  marginTop:    0, marginBottom: 0,
  marginLeft:   8, marginRight:  8,
  style: { background: "transparent", fontFamily: "'Lora', Georgia, serif" },
  x: { domain: [0, 4], axis: null },
  y: { domain: [0, 5], axis: null },
  marks: [
    Plot.rect([0,1,2,3].map(i=>({i})), { x1:d=>d.i, x2:d=>d.i+1, y1:0, y2:5, fill:d=>BG_HEX[d.i] }),
    Plot.ruleX([1,2,3], { stroke:"#ffffff", strokeWidth:2 }),
    Plot.rect(data, { x1:"x1", x2:"x2", y1:"y1", y2:"y2", fill:"color", rx:4 }),
    Plot.text(data, { x:"cx", y:d=>d.cy+0.13, text:"name", fill:"#ffffff", fontWeight:"600", fontSize:d=>d.name==="Bayesian Optimization"?12:13.5, textAnchor:"middle" }),
    Plot.text(data, { x:"cx", y:d=>d.cy-0.15, text:"sub",  fill:"#ffffff", fontSize:d=>(d.name==="Surrogates"||d.name==="State Estimation")?8.5:9.5, textAnchor:"middle", fillOpacity:0.80 }),
  ],
});

if (container) container.appendChild(chart);

// ── Highlight overlay ──────────────────────────────────────────────────────
const NS = "http://www.w3.org/2000/svg";
const hlRect = document.createElementNS(NS, "rect");
hlRect.setAttribute("fill", "none");
hlRect.setAttribute("stroke", "black");
hlRect.setAttribute("stroke-width", "2.5");
hlRect.setAttribute("rx", "4");
hlRect.setAttribute("pointer-events", "none");
hlRect.setAttribute("opacity", "0");
chart.appendChild(hlRect);

function plotToSvg(xp, yp) {
  return [
    8 + (xp / 4) * (w - 16),
    (1 - yp / 5) * h,
  ];
}

function updateHighlight(block) {
  if (!block) { hlRect.setAttribute("opacity", "0"); return; }
  const [sx1, sy2] = plotToSvg(block.x1, block.y1);
  const [sx2, sy1] = plotToSvg(block.x2, block.y2);
  hlRect.setAttribute("x",      sx1);
  hlRect.setAttribute("y",      sy1);
  hlRect.setAttribute("width",  sx2 - sx1);
  hlRect.setAttribute("height", sy2 - sy1);
  hlRect.setAttribute("opacity", "1");
}

// ── Refs panel ─────────────────────────────────────────────────────────────
const refsEl = document.getElementById("pai-refs");

function showRefs(block) {
  if (!block) {
    refsEl.innerHTML = '';
    return;
  }
  const sorted = [...block.refs].sort((a, b) => a.year - b.year);
  refsEl.innerHTML =
    `<div class="ref-header">${block.name}</div>` +
    sorted.map(r =>
      `<div class="ref-item"><span class="ref-year">${r.year}</span><span>${r.auth} — <em>${r.title}</em></span></div>`
    ).join('');
}

showRefs(null);

// ── Interaction: sticky — only update when entering a new block ────────────
let currentBlock = null;

function hitTest(e) {
  const r = chart.getBoundingClientRect();
  const plotX = (e.clientX - r.left - 8) / (r.width  - 16) * 4;
  const plotY = (1 - (e.clientY - r.top) / r.height)        * 5;
  return data.find(d => plotX >= d.x1 && plotX <= d.x2 && plotY >= d.y1 && plotY <= d.y2) || null;
}

chart.addEventListener('mousemove', e => {
  const hit = hitTest(e);
  if (hit && hit !== currentBlock) {
    currentBlock = hit;
    showRefs(currentBlock);
    updateHighlight(currentBlock);
  }
});
// mouseleave intentionally omitted — selection sticks until next block hover
</script>
